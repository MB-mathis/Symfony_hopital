{% extends 'base.html.twig' %}

{% block title %}Chirurgien{% endblock %}

{% block page_content %}
    <h1>Chirurgien</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ chirurgien.id }}</td>
            </tr>
            <tr>
                <th>Nom</th>
                <td>{{ chirurgien.nom }}</td>
            </tr>
            <tr>
                <th>Prenom</th>
                <td>{{ chirurgien.prenom }}</td>
            </tr>
            <tr>
                <th>CreatedAt</th>
                <td>{{ chirurgien.createdAt ? chirurgien.createdAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>UpdatedAt</th>
                <td>{{ chirurgien.updatedAt ? chirurgien.updatedAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path(constant('App\\Controller\\ChirurgienController::ROUTE_LIST')) }}">back to list</a>

    <a href="{{ path(constant('App\\Controller\\ChirurgienController::ROUTE_UPDATE'), {'id': chirurgien.id}) }}">edit</a>

    {{ include('chirurgien/_delete_form.html.twig') }}
{% endblock %}
