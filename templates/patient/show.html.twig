{# templates/patient/show.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Fiche Patient{% endblock %}

{% block body %}
<section class="section">
    <div class="container">
        <h1 class="title">Fiche Patient</h1>

        <div class="card">
            <header class="card-header">
                <p class="card-header-title">
                    {{ patient.nom }} {{ patient.prenom }}
                </p>
            </header>
            <div class="card-content">
                <div class="content">
                    <div class="columns is-multiline">
                        <div class="column is-half"><strong>ID :</strong> {{ patient.id }}</div>
                        <div class="column is-half"><strong>Nom :</strong> {{ patient.nom }}</div>
                        <div class="column is-half"><strong>Prénom :</strong> {{ patient.prenom }}</div>
                        <div class="column is-half"><strong>Date de naissance :</strong> {{ patient.dateNaissance ? patient.dateNaissance|date('d/m/Y') : '' }}</div>
                        <div class="column is-half"><strong>Sexe :</strong> {{ patient.sexe.value }}</div>
                        <div class="column is-half"><strong>Ville :</strong> {{ patient.ville }}</div>
                        <div class="column is-half"><strong>Code Postal :</strong> {{ patient.codePostal }}</div>
                        <div class="column is-half"><strong>Téléphone :</strong> {{ patient.telephone }}</div>
                        <div class="column is-half"><strong>Email :</strong> {{ patient.email }}</div>
                        <div class="column is-half"><strong>Créé le :</strong> {{ patient.createdAt ? patient.createdAt|date('d/m/Y H:i') : '' }}</div>
                        <div class="column is-half"><strong>Créé par :</strong> {{ patient.createdBy ? (patient.createdBy.nom ~ ' ' ~ patient.createdBy.prenom)|trim ?: patient.createdBy.userIdentifier : '' }}</div>
                        <div class="column is-half"><strong>Dernière modification :</strong> {{ patient.updatedAt ? patient.updatedAt|date('d/m/Y H:i') : '' }}</div>
                    </div>

                    {# Affichage des utilisateurs partagés si existants #}
                    {% if patient.patientUserShares|length > 0 %}
                        <div class="mt-4">
                            <strong>Partagé avec :</strong>
                            <ul>
                                {% for share in patient.patientUserShares %}
                                    <li>{{ (share.user.nom ~ ' ' ~ share.user.prenom)|trim ?: share.user.userIdentifier }}</li>
                                {% endfor %}
                            </ul>
                        </div>
                    {% endif %}
                </div>
            </div>
            <footer class="card-footer">
                <a href="{{ path('app_patient_edit', {'id': patient.id}) }}" class="card-footer-item button is-link is-light">Modifier</a>
                <a href="{{ path('app_patient_index') }}" class="card-footer-item button is-light">Retour à la liste</a>
                {# <span class="card-footer-item">
                    {{ include('patient/_delete_form.html.twig', {'patient': patient}) }}
                </span> #}
            </footer>
        </div>
    </div>
</section>
{% endblock %}