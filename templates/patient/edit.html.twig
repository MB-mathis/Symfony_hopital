{# templates/patient/edit.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Modifier un patient{% endblock %}

{% block body %}
<section class="section">
    <div class="container">
        <h1 class="title">Modifier un patient</h1>

        {{ form_start(form, {'attr': {'class': 'form'}}) }}

        <div class="columns is-multiline">
            <div class="column is-half">
                <div class="field">
                    {{ form_label(form.nom) }}
                    <div class="control">
                        {{ form_widget(form.nom, {'attr': {'class': 'input'}}) }}
                    </div>
                    {{ form_errors(form.nom) }}
                </div>
            </div>

            <div class="column is-half">
                <div class="field">
                    {{ form_label(form.prenom) }}
                    <div class="control">
                        {{ form_widget(form.prenom, {'attr': {'class': 'input'}}) }}
                    </div>
                    {{ form_errors(form.prenom) }}
                </div>
            </div>

            <div class="column is-half">
                <div class="field">
                    {{ form_label(form.dateNaissance) }}
                    <div class="control">
                        {{ form_widget(form.dateNaissance, {'attr': {'class': 'input', 'type': 'date'}}) }}
                    </div>
                    {{ form_errors(form.dateNaissance) }}
                </div>
            </div>

            <div class="column is-half">
                <div class="field">
                    {{ form_label(form.sexe) }}
                    <div class="control">
                        {{ form_widget(form.sexe, {'attr': {'class': 'select'}}) }}
                    </div>
                    {{ form_errors(form.sexe) }}
                </div>
            </div>

            <div class="column is-half">
                <div class="field">
                    {{ form_label(form.ville) }}
                    <div class="control">
                        {{ form_widget(form.ville, {'attr': {'class': 'input'}}) }}
                    </div>
                    {{ form_errors(form.ville) }}
                </div>
            </div>

            <div class="column is-half">
                <div class="field">
                    {{ form_label(form.codePostal) }}
                    <div class="control">
                        {{ form_widget(form.codePostal, {'attr': {'class': 'input'}}) }}
                    </div>
                    {{ form_errors(form.codePostal) }}
                </div>
            </div>

            <div class="column is-half">
                <div class="field">
                    {{ form_label(form.telephone) }}
                    <div class="control">
                        {{ form_widget(form.telephone, {'attr': {'class': 'input'}}) }}
                    </div>
                    {{ form_errors(form.telephone) }}
                </div>
            </div>

            <div class="column is-half">
                <div class="field">
                    {{ form_label(form.email) }}
                    <div class="control">
                        {{ form_widget(form.email, {'attr': {'class': 'input'}}) }}
                    </div>
                    {{ form_errors(form.email) }}
                </div>
            </div>

            {# Affiche le champ seulement s'il est présent #}
            {% if form.patientUserShares is defined %}
                <div class="column is-full">
                    <div class="field">
                        <label class="label">Partager avec :</label>
                        <div class="control">
                            {{ include('patient/_collection_patient_user_shares.html.twig', { form: form }) }}
                        </div>
                        {{ form_errors(form.patientUserShares) }}
                    </div>
                </div>
            {% endif %}
        </div>
        
        <div class="field is-grouped">
            <div class="control">
                <button class="button is-primary">Mettre à jour</button>
            </div>
            <div class="control">
                <a href="{{ path(constant('App\\Controller\\PatientController::ROUTE_LIST')) }}" class="button is-light">Annuler</a>
            </div>
        </div>

        {{ form_end(form) }}

        {# Bouton de suppression #}
        {# {{ include('patient/_delete_form.html.twig', {'patient': patient}) }} #}
    </div>
</section>
{% endblock %}