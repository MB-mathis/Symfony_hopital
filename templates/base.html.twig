<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Hôpital{% endblock %}</title>

    <meta name="viewport" content="width=device-width, initial-scale=1">

    {% block stylesheets %}
        {{ encore_entry_link_tags('app') }}
    {% endblock %}

    {% block javascripts %}
        {{ encore_entry_script_tags('app') }}
    {% endblock %}
</head>

<body>

{% block body %}

{# ================= NAVBAR ================= #}
<nav class="navbar is-white has-shadow is-fixed-top">
    <div class="navbar-brand">
        <a class="navbar-item" href="{{ path(constant('App\\Controller\\DashboardController::ROUTE_INDEX')) }}">
            <strong>🏥 Hopital Manager</strong>
        </a>
    </div>

    <div class="navbar-end pr-4">
        {% if app.user %}
            <div class="navbar-item">
                {{ app.user.prenom ?? app.user.userIdentifier }}
            </div>

            <div class="navbar-item">
                <a href="{{ path(constant('App\\Controller\\SecurityController::ROUTE_LOGOUT')) }}">
                    Déconnexion
                </a>
            </div>
        {% else %}
            <div class="navbar-item">
                <a href="{{ path(constant('App\\Controller\\SecurityController::ROUTE_LOGIN')) }}">
                    Connexion
                </a>
            </div>
        {% endif %}
    </div>
</nav>

{# ================= LAYOUT ================= #}
<div class="app-shell">

    {# ===== SIDEBAR ===== #}
    <aside class="app-sidebar">
        <div class="p-4">

            <p class="menu-label">Navigation</p>

            <ul class="menu-list">

                <li>
                    <a href="{{ path(constant('App\\Controller\\DashboardController::ROUTE_INDEX')) }}"
                       class="{% if app.request.attributes.get('_route') == constant('App\\Controller\\DashboardController::ROUTE_INDEX') %}is-active{% endif %}">
                        Dashboard
                    </a>
                </li>

                <li>
                    <a href="{{ path(constant('App\\Controller\\PatientController::ROUTE_LIST')) }}"
                       class="{% if app.request.attributes.get('_route') starts with 'patient' %}is-active{% endif %}">
                        Patients
                    </a>
                </li>

                <li>
                    <a href="{{ path(constant('App\\Controller\\GreffeController::ROUTE_LIST')) }}"
                       class="{% if app.request.attributes.get('_route') starts with 'greffe' %}is-active{% endif %}">
                        Greffes
                    </a>
                </li>

                <li>
                    <a href="{{ path(constant('App\\Controller\\DonneurController::ROUTE_LIST')) }}"
                       class="{% if app.request.attributes.get('_route') starts with 'donneur' %}is-active{% endif %}">
                        Donneurs
                    </a>
                </li>

                <li>
                    <a href="{{ path(constant('App\\Controller\\ChirurgienController::ROUTE_LIST')) }}"
                       class="{% if app.request.attributes.get('_route') starts with 'chirurgien' %}is-active{% endif %}">
                        Chirurgiens
                    </a>
                </li>

                <li>
                    <a href="{{ path(constant('App\\Controller\\UserController::ROUTE_LIST')) }}"
                       class="{% if app.request.attributes.get('_route') starts with 'user' %}is-active{% endif %}">
                        Utilisateurs
                    </a>
                </li>

            </ul>
        </div>
    </aside>

    {# ===== MAIN ===== #}
    <main class="app-main">

        <div class="app-content">

            {# FLASH #}
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="notification is-{{ label }}">
                        {{ message }}
                    </div>
                {% endfor %}
            {% endfor %}

            {# HEADER + BREADCRUMB #}
            <div class="page-header">

                <div>

                    {# BREADCRUMB #}
                    <nav class="breadcrumb mb-2" aria-label="breadcrumbs">
                        <ul>
                            <li>
                                <a href="{{ path(constant('App\\Controller\\DashboardController::ROUTE_INDEX')) }}">
                                    Accueil
                                </a>
                            </li>
                            <li class="is-active">
                                <a aria-current="page">
                                    {{ block('title') }}
                                </a>
                            </li>
                        </ul>
                    </nav>

                    {# TITRE #}
                    <h1 class="title">
                        {% block page_title %}{{ block('title') }}{% endblock %}
                    </h1>

                    <h2 class="subtitle">
                        {% block page_subtitle %}{% endblock %}
                    </h2>

                </div>

                <div>
                    {% block page_action %}{% endblock %}
                </div>

            </div>

            {# CONTENT #}
            {% block page_content %}{% endblock %}

        </div>

    </main>

</div>

{% endblock %}

</body>
</html>