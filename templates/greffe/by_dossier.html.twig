{% extends 'base.html.twig' %}

{% block title %}Greffes du dossier{% endblock %}

{% block body %}
<section class="section">
    <div class="container">

        <h1 class="title">
            Greffes du dossier {{ dossier.numeroDossier }}
        </h1>

        {% if greffes is empty %}
            <div class="notification is-warning">
                Aucune greffe enregistrée pour ce dossier.
            </div>
        {% endif %}

        <div class="columns is-multiline">

            {% for greffe in greffes %}
                <div class="column is-6">
                    <div class="card">

                        <div class="card-content">

                            <p class="title is-5">
                                Greffe n°{{ greffe.rangGreffe }}
                            </p>

                            <p><strong>Date :</strong> {{ greffe.dateGreffe|date('d/m/Y') }}</p>
                            <p><strong>Type :</strong> {{ greffe.typeGreffe.value }}</p>
                            <p>
                                <strong>Greffon fonctionnel :</strong>
                                {{ greffe.greffonFonctionnel ? 'Oui' : 'Non' }}
                            </p>

                            <hr>

                            <p>
                                <strong>Donneur :</strong>
                                {{ greffe.donneur.numeroCrista }}
                            </p>

                            <p>
                                <strong>Chirurgien :</strong>
                                {{ greffe.chirurgien.nom }} {{ greffe.chirurgien.prenom }}
                            </p>

                        </div>

                        <footer class="card-footer">

                            {# Voir détail greffe #}
                            <a href="{{ path(constant('App\\Controller\\GreffeController::ROUTE_SHOW'), {id: greffe.id}) }}" class="card-footer-item">
                                Voir détail
                            </a>

                            {# Accès donneur #}
                            <a href="{{ path(constant('App\\Controller\\DonneurController::ROUTE_SHOW'), {id: greffe.donneur.id}) }}"
                               class="card-footer-item">
                                Voir donneur
                            </a>

                        </footer>

                    </div>
                </div>
            {% endfor %}

        </div>

    </div>
</section>
{% endblock %}