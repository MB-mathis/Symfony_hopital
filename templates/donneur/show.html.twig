{% extends 'base.html.twig' %}

{% block title %}Donneur{% endblock %}

{% block body %}
    <h1>Donneur</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ donneur.id }}</td>
            </tr>
            <tr>
                <th>GroupeSanguin</th>
                <td>{{ donneur.groupeSanguin.value }}</td>
            </tr>
            <tr>
                <th>Sexe</th>
                <td>{{ donneur.sexe.value}}</td>
            </tr>
            <tr>
                <th>Taille</th>
                <td>{{ donneur.taille }}</td>
            </tr>
            <tr>
                <th>Data</th>
                <td>{{ donneur.data ? donneur.data|json_encode : '' }}</td>
            </tr>
            <tr>
                <th>TypeDonneur</th>
                <td>{{ donneur.typeDonneur.value }}</td>
            </tr>
            <tr>
                <th>DateNaissance</th>
                <td>{{ donneur.dateNaissance ? donneur.dateNaissance|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>Poids</th>
                <td>{{ donneur.poids }}</td>
            </tr>
            <tr>
                <th>CreatedAt</th>
                <td>{{ donneur.createdAt ? donneur.createdAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>UpdatedAt</th>
                <td>{{ donneur.updatedAt ? donneur.updatedAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>NumeroCrista</th>
                <td>{{ donneur.numeroCrista }}</td>
            </tr>
            <tr>
                <th>Imc</th>
                <td>{{ donneur.imc }}</td>
            </tr>
            <tr>
                <th>Dfg</th>
                <td>{{ donneur.dfg }}</td>
            </tr>
            <tr>
                <th>ClairanceCalculée</th>
                <td>{{ donneur.clairanceCalculee }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_donneur_index') }}">back to list</a>

    <a href="{{ path('app_donneur_edit', {'id': donneur.id}) }}">edit</a>

    {{ include('donneur/_delete_form.html.twig') }}
{% endblock %}
