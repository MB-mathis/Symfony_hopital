{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}
<section class="section has-background-dark">
    <div class="container">
        <div class="columns is-centered is-vcentered" style="min-height: 90vh;">
            <div class="column is-4">

                <div class="box has-background-black">

                    <!-- Logo -->
                    <div class="has-text-centered mb-5">
                        <span class="icon is-large has-text-info">
                            <i class="fas fa-heartbeat fa-3x"></i>
                        </span>
                        <h1 class="title has-text-white mt-3">Hopital Symfony</h1>
                        <p class="subtitle is-6 has-text-grey-light">
                            Plateforme médicale sécurisée
                        </p>
                    </div>

                    {% if error %}
                        <div class="notification is-danger">
                            {{ error.messageKey|trans(error.messageData, 'security') }}
                        </div>
                    {% endif %}

                    <form method="post">

                        <div class="field">
                            <label class="label has-text-grey-light">Email</label>
                            <div class="control has-icons-left">
                                <input class="input has-background-dark has-text-white"
                                       type="email"
                                       value="{{ last_username }}"
                                       name="email"
                                       required autofocus>
                                <span class="icon is-small is-left">
                                    <i class="fas fa-envelope"></i>
                                </span>
                            </div>
                        </div>

                        <div class="field">
                            <label class="label has-text-grey-light">Mot de passe</label>
                            <div class="control has-icons-left">
                                <input class="input has-background-dark has-text-white"
                                       type="password"
                                       name="password"
                                       required>
                                <span class="icon is-small is-left">
                                    <i class="fas fa-lock"></i>
                                </span>
                            </div>
                        </div>

                        <input type="hidden" name="_csrf_token"
                               value="{{ csrf_token('authenticate') }}">

                        <div class="field">
                            <label class="checkbox has-text-grey-light">
                                <input type="checkbox" name="_remember_me">
                                Se souvenir de moi
                            </label>
                        </div>

                        <div class="field">
                            <button class="button is-info is-fullwidth is-medium">
                                Se connecter
                            </button>
                        </div>

                    </form>
                </div>

                <p class="has-text-centered mt-4 has-text-grey">
                    © 2026 Hopital Symfony — Sécurité renforcée 🔒
                </p>

            </div>
        </div>
    </div>
</section>
{% endblock %}